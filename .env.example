# Configuration CANAL CICA - Variables d'Environnement

# ╔══════════════════════════════════════════════════════════╗
# ║            APPLICATION SETTINGS                         ║
# ╚══════════════════════════════════════════════════════════╝

# Nom de l'application
VITE_APP_NAME=CANAL CICA

# Mode application (development, production, staging)
VITE_APP_MODE=development

# Version de l'application
VITE_APP_VERSION=1.0.0

# ╔══════════════════════════════════════════════════════════╗
# ║            API CONFIGURATION                            ║
# ╚══════════════════════════════════════════════════════════╝

# URL de base de l'API
VITE_API_URL=http://localhost:3000

# Timeout des requêtes (en millisecondes)
VITE_API_TIMEOUT=30000

# ╔══════════════════════════════════════════════════════════╗
# ║            AUTHENTICATION                               ║
# ╚══════════════════════════════════════════════════════════╝

# Clé pour stocker le token dans localStorage
VITE_AUTH_TOKEN_KEY=cica_token

# Clé pour stocker l'utilisateur dans localStorage
VITE_AUTH_USER_KEY=cica_user

# Durée de session (en millisecondes) - 30 minutes
VITE_SESSION_TIMEOUT=1800000

# Refresh token interval (en millisecondes) - 25 minutes
VITE_REFRESH_TOKEN_INTERVAL=1500000

# ╔══════════════════════════════════════════════════════════╗
# ║            FEATURES & FEATURE FLAGS                     ║
# ╚══════════════════════════════════════════════════════════╝

# Activer les logs détaillés
VITE_DEBUG_MODE=true

# Activer les mocks des données (pour développement)
VITE_USE_MOCK_DATA=false

# Activer la pagination par défaut
VITE_ENABLE_PAGINATION=true

# Éléments par page par défaut
VITE_DEFAULT_PAGE_SIZE=10

# ╔══════════════════════════════════════════════════════════╗
# ║            SERVICES EXTERNES                            ║
# ╚══════════════════════════════════════════════════════════╝

# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=

# Sentry (Error tracking)
VITE_SENTRY_DSN=

# ╔══════════════════════════════════════════════════════════╗
# ║            PATHS & URLS                                 ║
# ╚══════════════════════════════════════════════════════════╝

# URL publique de l'application
VITE_PUBLIC_URL=http://localhost:5173

# URL pour les images/assets/uploads
VITE_ASSETS_URL=http://localhost:3000/uploads

# ╔══════════════════════════════════════════════════════════╗
# ║            NOTES                                        ║
# ╚══════════════════════════════════════════════════════════╝

# 1. Copier ce fichier en .env.local pour développement local
# 2. Copier ce fichier en .env.production pour production
# 3. NE JAMAIS committer les vrais secrets dans le repo

# Copier et renommer selon l'environnement:
# - .env.local (développement)
# - .env.production (production)
# - .env.staging (staging)
